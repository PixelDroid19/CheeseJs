{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "types": ["vitest/globals", "node", "electron"],
    "baseUrl": ".",
    "paths": {
      "@cheesejs/app": ["packages/app/src/index.ts"],
      "@cheesejs/app/*": ["packages/app/src/*"],
      "@cheesejs/core": ["packages/core/src/index.ts"],
      "@cheesejs/core/*": ["packages/core/src/*"],
      "@cheesejs/editor": ["packages/editor/src/index.ts"],
      "@cheesejs/editor/*": ["packages/editor/src/*"],
      "@cheesejs/execution": ["packages/execution/src/index.ts"],
      "@cheesejs/execution/*": ["packages/execution/src/*"],
      "@cheesejs/frontend": ["packages/frontend/src/index.ts"],
      "@cheesejs/frontend/*": ["packages/frontend/src/*"],
      "@cheesejs/languages": ["packages/languages/src/index.ts"],
      "@cheesejs/languages/*": ["packages/languages/src/*"],
      "@cheesejs/package-management": [
        "packages/package-management/src/index.ts"
      ],
      "@cheesejs/package-management/*": ["packages/package-management/src/*"],
      "@cheesejs/runtime-shell": ["packages/runtime-shell/src/index.ts"],
      "@cheesejs/runtime-shell/*": ["packages/runtime-shell/src/*"],
      "@cheesejs/settings": ["packages/settings/src/index.ts"],
      "@cheesejs/settings/*": ["packages/settings/src/*"],
      "@cheesejs/themes": ["packages/themes/src/index.ts"],
      "@cheesejs/themes/*": ["packages/themes/src/*"],
      "@cheesejs/ui": ["packages/ui/src/index.ts"],
      "@cheesejs/ui/*": ["packages/ui/src/*"],
      "@cheesejs/workbench": ["packages/workbench/src/index.ts"],
      "@cheesejs/workbench/*": ["packages/workbench/src/*"]
    },

    /* Module resolution */
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["electron", "shared", "packages"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
